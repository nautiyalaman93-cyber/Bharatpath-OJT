# ================================================================
# BharatPath - Environment Variables
# ================================================================
# Fill in the values below from RapidAPI after subscribing.
# Restart the dev server (npm run dev) after any changes here.
# ================================================================

# --- 1. Station Search API ---
# Provider: e.g. "Indian Railway API" on RapidAPI
# Endpoint: /searchStation?query={str}
VITE_STATION_SEARCH_API_HOST=
VITE_STATION_SEARCH_API_KEY=

# --- 2. Train Search (Between Stations) API ---
# Provider: e.g. "Indian Railway API" on RapidAPI
# Endpoint: /trainsBetweenStations?from={code}&to={code}&date={date}
VITE_TRAIN_SEARCH_API_HOST=
VITE_TRAIN_SEARCH_API_KEY=

# --- 3. Live Train Status API ---
# Provider: e.g. "RailwayAPI" on RapidAPI
# Endpoint: /liveTrainStatus?trainNo={trainNo}&date={date}
VITE_LIVE_STATUS_API_HOST=
VITE_LIVE_STATUS_API_KEY=

# --- 4. PNR Status API ---
# Provider: e.g. "IRCTC API" on RapidAPI
# Endpoint: /pnrStatus?pnr={10_digit}
VITE_PNR_API_HOST=
VITE_PNR_API_KEY=

# --- FUTURE: Your Own Backend ---
# When you build a backend, set this URL and remove the keys above.
# Your backend will hold the API keys securely server-side.
VITE_BACKEND_URL=
